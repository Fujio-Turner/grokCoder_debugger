# ──────────────────────────────────────────────────────────────
# Couchbase Capella (existing)
# ──────────────────────────────────────────────────────────────
CB_HOST=your-capella-host.data.cloud.couchbase.com
CB_USER=your_username
CB_PASS=your_password
CB_BUCKET=grokCoder
CB_SCOPE=continue
CB_COLLECTION=report
CB_FTS_INDEX=grokCoder_Dugger_v1

# ──────────────────────────────────────────────────────────────
# Grok / xAI  (for the auto-triage pipeline — see docs/work/)
# Get a key at: https://console.x.ai/  → API Keys
# ──────────────────────────────────────────────────────────────
GROK_API_KEY=xai-...your-key-here...
GROK_MODEL=grok-4-latest
# Premium tier alternatives (more expensive but better RCA):
# GROK_MODEL=grok-4.2.0
# GROK_MODEL=grok-4.3.0
GROK_API_URL=https://api.x.ai/v1/chat/completions
GROK_TIMEOUT_SEC=360

# ──────────────────────────────────────────────────────────────
# GitHub (for filing issues from triage results)
# Create a fine-grained PAT with `Issues: Read & Write` on the
# target repo: https://github.com/settings/personal-access-tokens
# ──────────────────────────────────────────────────────────────
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=Fujio-Turner/continue-vscode-todos-tool

# ──────────────────────────────────────────────────────────────
# Triage pipeline behavior
# ──────────────────────────────────────────────────────────────
DAILY_ISSUE_QUOTA=10
POLL_INTERVAL_SEC=60
POLLER_ENABLED=true
STATE_FILE=/data/state.json
